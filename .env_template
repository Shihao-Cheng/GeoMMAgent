#===========================================
# MODEL & API 
# (See https://docs.camel-ai.org/key_modules/models.html#)
#===========================================

# OPENAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY="Your_Key"
# OPENAI_API_BASE_URL=""


# Qwen API (https://help.aliyun.com/zh/model-studio/developer-reference/get-api-key)
# QWEN_API_KEY="Your_Key"
# QWEN_API_BASE_URL=""

# DeepSeek API (https://platform.deepseek.com/api_keys)
# DEEPSEEK_API_KEY="Your_Key"
# DEEPSEEK_API_BASE_URL=""

# PPIO API (https://ppinfra.com/settings/key-management?utm_source=github_owl)
# PPIO_API_KEY="Your_Key"

# GROQ API (https://console.groq.com/)
# GROQ_API_KEY="Your_Key"
# GROQ_API_BASE_URL=""

# Azure OpenAI API
# AZURE_OPENAI_BASE_URL=""
# AZURE_API_VERSION=""
# AZURE_OPENAI_API_KEY="Your_Key"
# AZURE_DEPLOYMENT_NAME=""

#GOOGLE GEMINI API (https://ai.google.dev/gemini-api/docs/api-key)
# GEMINI_API_KEY ="Your_Key"

# NOVITA API (https://novita.ai/settings/key-management?utm_source=github_owl&utm_medium=github_readme&utm_campaign=github_link)
# NOVITA_API_KEY="Your_Key"

#===========================================
# Tools & Services API
#===========================================

# Google Programmable Search Engine (Custom Search JSON API)
# https://developers.google.com/custom-search/v1/overview
# Web + image modes both use the same key/cx; enable "Image search" in CSE if image results are empty.
GOOGLE_API_KEY="Your_Key"
SEARCH_ENGINE_ID="Your_ID"

# Wikipedia summaries use CAMEL SearchToolkit.search_wiki (requires: pip install wikipedia)

# Search evidence / GME — defaults live in configs/GeoMMBench.yaml under ``gme:``.
# Any GEOMM_* set here overrides YAML (dotenv loads before build_agents_from_config uses setdefault).

# GEOMM_MAX_EVIDENCE_IMAGES=4
# GEOMM_GME_MODEL_PATH=/path/to/gme-Qwen2-VL-2B-Instruct
# GEOMM_GME_TOP_K=12
# GEOMM_GME_IMG_BATCH=8
# GEOMM_GME_DISABLE=1
# GEOMM_GME_NOOP=1
# GME remote code: transformers<4.52 recommended (e.g. pip install transformers==4.51.3)

# Detection (YOLO-OBB) — used when AgentCoordinator runs the DetAgent step
# (see coordinator/coordinator.py:_run_yolo_detection_for_det_step). Default: weights/yolo11s-obb.pt
# GEOMM_DET_YOLO_PATH=/path/to/yolo11s-obb.pt

# Segmentation (DeepLabV3+ Xception) — defaults: configs/GeoMMBench.yaml → SegAgent.deeplab_weights
# GEOMM_DEEPLAB_WEIGHTS=/path/to/deeplabv3plus-loveda.pth
# GEOMM_DEEPLAB_NUM_CLASSES=7
# GEOMM_DEEPLAB_OUTPUT_STRIDE=16

# Chunkr API (https://chunkr.ai/)
CHUNKR_API_KEY="Your_Key"

# Firecrawl API (https://www.firecrawl.dev/)
FIRECRAWL_API_KEY="Your_Key"
#FIRECRAWL_API_URL="https://api.firecrawl.dev"